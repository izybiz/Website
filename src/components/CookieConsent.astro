---
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const texts: Record<string, { message: string; accept: string; decline: string; manage: string; link: string }> = {
  fr: {
    message: "Ce site utilise Google Analytics pour mesurer l'audience. Ces cookies ne sont déposés qu'avec votre accord.",
    accept: "Accepter",
    decline: "Refuser",
    manage: "Paramètres cookies",
    link: "/donnees-personnelles/",
  },
  en: {
    message: "This site uses Google Analytics to measure traffic. Cookies are only set with your consent.",
    accept: "Accept",
    decline: "Decline",
    manage: "Cookie settings",
    link: "/donnees-personnelles/",
  },
  es: {
    message: "Este sitio usa Google Analytics para medir el tráfico. Las cookies solo se instalan con su consentimiento.",
    accept: "Aceptar",
    decline: "Rechazar",
    manage: "Configuración de cookies",
    link: "/donnees-personnelles/",
  },
};

const t = texts[lang] ?? texts.fr;
---

<div
  id="cookie-banner"
  class="cookie-banner"
  role="region"
  aria-label="Consentement cookies"
  hidden
>
  <p class="cookie-banner__text">
    {t.message}
    <a href={t.link} class="cookie-banner__link">En savoir plus</a>
  </p>
  <div class="cookie-banner__actions">
    <button id="cookie-accept" class="cookie-banner__btn cookie-banner__btn--accept">
      {t.accept}
    </button>
    <button id="cookie-decline" class="cookie-banner__btn cookie-banner__btn--decline">
      {t.decline}
    </button>
  </div>
</div>

<!-- Small trigger to reopen banner after choice -->
<button
  id="cookie-manage"
  class="cookie-manage-btn"
  aria-label={t.manage}
  title={t.manage}
  hidden
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.25"/>
    <circle cx="7" cy="7" r="1.75" fill="currentColor"/>
  </svg>
</button>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1.25rem;
    left: 1.25rem;
    right: 1.25rem;
    max-width: 36rem;
    background: #111;
    color: #f0f0f0;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.22);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    font-family: "Didact Gothic", sans-serif;
  }

  .cookie-banner__text {
    margin: 0;
  }

  .cookie-banner__link {
    color: #a5b4fc;
    margin-left: 0.2rem;
  }

  .cookie-banner__actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .cookie-banner__btn {
    padding: 0.4rem 1.1rem;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: inherit;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .cookie-banner__btn:hover {
    opacity: 0.82;
  }

  .cookie-banner__btn--accept {
    background: #f0f0f0;
    color: #111;
  }

  .cookie-banner__btn--decline {
    background: transparent;
    color: #f0f0f0;
    border: 1px solid rgba(240, 240, 240, 0.2);
  }

  .cookie-manage-btn {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 50%;
    background: #111;
    color: #f0f0f0;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    opacity: 0.45;
    transition: opacity 0.15s;
  }

  .cookie-manage-btn:hover {
    opacity: 1;
  }
</style>

<script is:inline>
  (function () {
    var banner = document.getElementById('cookie-banner');
    var manageBtn = document.getElementById('cookie-manage');

    function updateConsent(state) {
      if (typeof gtag === 'function') {
        gtag('consent', 'update', {
          analytics_storage: state,
          ad_storage: 'denied',
        });
      }
    }

    function showBanner() {
      if (banner) banner.hidden = false;
      if (manageBtn) manageBtn.hidden = true;
    }

    function hideBanner() {
      if (banner) banner.hidden = true;
      if (manageBtn) manageBtn.hidden = false;
    }

    var saved = localStorage.getItem('cookie_consent');
    if (!saved) {
      showBanner();
    } else {
      hideBanner();
    }

    var acceptBtn = document.getElementById('cookie-accept');
    var declineBtn = document.getElementById('cookie-decline');

    if (acceptBtn) {
      acceptBtn.addEventListener('click', function () {
        localStorage.setItem('cookie_consent', 'granted');
        updateConsent('granted');
        hideBanner();
      });
    }

    if (declineBtn) {
      declineBtn.addEventListener('click', function () {
        localStorage.setItem('cookie_consent', 'denied');
        updateConsent('denied');
        hideBanner();
      });
    }

    if (manageBtn) {
      manageBtn.addEventListener('click', function () {
        localStorage.removeItem('cookie_consent');
        showBanner();
      });
    }
  })();
</script>
