---
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog-en"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<main class="page-shell">
      <section class="section-one" aria-label="Section 1">
        <div class="hero-izybiz">
          <div class="hero-izybiz__text">
            <h1 class="hero-izybiz__title">
              <span class="hero-izybiz__title-line"
                >Making AI effective where <br />
                it counts: in your operations</span
              >
            </h1>
            <p class="hero-izybiz__subtitle">
              <span>
                Interim management and AI integration to regain control of priorities, accelerate execution, and deliver measurable results.
              </span>
            </p>
          </div>

          <div class="hero-izybiz__actions">
            <a class="hero-izybiz__button" href="/en/contact/">
              Book a call
            </a>
            <a
              class="hero-izybiz__button hero-izybiz__button--secondary"
              href="https://www.linkedin.com/company/izybiz/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Open the IZYBIZ LinkedIn page in a new tab"
            >
              Send a LinkedIn message
            </a>
          </div>
        </div>

        <section class="hero-metrics" aria-label="Key performance highlights">
          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="95">0%</p>
            <p class="hero-metrics__description">
              Of failure rate for generative AI projects in businesses.
            </p>
          </article>

          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="23">0%</p>
            <p class="hero-metrics__description">
              Of leaders can link their AI investments to a measurable financial
              outcome.
            </p>
          </article>

          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="84">0%</p>
            <p class="hero-metrics__description">
              Of AI failures are due to poor management, not the technology
              itself.
            </p>
          </article>
        </section>

        <section class="home-transition" aria-labelledby="home-transition-title">
          <div class="home-transition__intro">
            <h2 class="home-transition__title" id="home-transition-title">
              Interim management<br class="home-transition__title-break" />for critical phases
            </h2>
            <p class="home-transition__description">
              When an activity drifts, a strategic project stalls, or a transformation needs to deliver fast, a framework isn't enough. You need operational leadership that can take the reins, set priorities, and hold execution.
            </p>
            <a class="home-transition__more" href="/en/management-transition/">Our interim management approach</a>
          </div>

          <ul class="blog-list home-transition__posts" aria-label="Latest articles">
            {latestPosts.map((post) => {
              const slug = post.id.replace(/\.md$/, "");
              const date = post.data.pubDate.toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" });

              return (
                <li class="blog-card">
                  <a class="blog-card__link" href={`/en/blog/${slug}/`}>
                    <time class="blog-card__date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                    <div class="blog-card__content">
                      <h3 class="blog-card__title">{post.data.title}</h3>
                      <p class="blog-card__description">{post.data.description}</p>
                    </div>
                    <span class="blog-card__cta">Read article</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>

        <section class="home-ai" aria-labelledby="home-ai-title">
          <div class="home-ai__inner">
            <h2 class="home-ai__title" id="home-ai-title">
              Integrating AI without losing operational control
            </h2>
            <p class="home-ai__description">
              AI creates value when it fits within clear priorities, controlled processes, and explicit accountability.
            </p>
            <a class="home-ai__more" href="/en/ai-integration/">Our enterprise AI integration approach</a>
          </div>
          <section class="hero-video" aria-label="Izybiz showcase video">
            <video class="hero-video__media" controls preload="metadata">
              <source src="/assets/Anim-Izybiz-V2.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </section>
        </section>

        <section
          class="we-deliver"
          id="we-deliver"
          aria-labelledby="we-deliver-title"
        >
          <div class="we-deliver__intro">
            <h2 class="we-deliver__title" id="we-deliver-title">
              Measurable results, not advisory recommendations
            </h2>
            <p class="we-deliver__intro-copy">
              A useful mission is judged on what it changes in operations, not on the quality of the slides. From day one, we clarify objectives, the indicators to track, and the initiatives to prioritise. The goal is simple: produce visible, readable, and measurable effects.
            </p>
          </div>

          <div class="we-deliver__cards-row" aria-label="We deliver cards">
            <article
              class="we-deliver__card we-deliver__card--dna"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--dna"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--dna.svg"
                    alt=""
                  />
                </div>
                <div
                  class="we-deliver__card-content we-deliver__card-content--dna"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--dna"
                  >
                    WHAT YOU BRING IN
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--dna"
                    aria-label="Your DNA deliverables"
                  >
                    <span class="we-deliver__card-tab">Business goals</span>
                    <span class="we-deliver__card-tab">Key processes</span>
                    <span class="we-deliver__card-tab">Constraints</span>
                    <span class="we-deliver__card-tab">Requirements</span>
                    <span class="we-deliver__card-tab">Internal teams</span>
                    <span class="we-deliver__card-tab">Existing tools</span>
                  </div>
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--agent"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--agent"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--agent"
                  >
                    WHAT WE STRUCTURE
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--agent"
                    aria-label="Agent Factory deliverables"
                  >
                    <span class="we-deliver__card-tab">Use case framing</span>
                    <span class="we-deliver__card-tab">Vendor selection</span>
                    <span class="we-deliver__card-tab">Technology choice</span>
                    <span class="we-deliver__card-tab">AI workflow</span>
                    <span class="we-deliver__card-tab">Human checkpoints</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--agent"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--agent.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--output"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--output"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--output"
                  >
                    WHAT YOU OWN
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--output"
                    aria-label="Customer ready output deliverables"
                  >
                    <span class="we-deliver__card-tab">Running AI system</span>
                    <span
                      class="we-deliver__card-tab we-deliver__card-tab--output-workflow"
                      >Documented workflows</span
                    >
                    <span class="we-deliver__card-tab">Trained team</span>
                    <span class="we-deliver__card-tab"
                      >Clear accountability</span
                    >
                    <span class="we-deliver__card-tab">Full independence</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--output"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--output.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>
          </div>
          <div class="we-deliver__services-link">
            <a href="/en/services/">See all our missions</a>
          </div>
        </section>
      </section>

      <section class="section-two" id="we-do" aria-label="Case studies">
        <div class="section-two__inner">
          <header class="section-two__intro">
            <h2 class="section-two__title" id="case-studies-heading">
              Our latest missions
            </h2>
            <div
              class="section-two__topbar"
              aria-label="Case studies navigation"
            >
              <div
                class="section-two__tabs"
                role="tablist"
                aria-label="Case studies tabs"
                data-case-tablist
              >
                <button
                  class="section-two__tab is-active"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Telecom &amp; Fintech · Africa
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Community Marketplace · Africa
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Community Cooking · Europe
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Agentic Delivery · France
                </button>
              </div>

              <div class="section-two__mobile-nav">
                <span
                  class="section-two__counter"
                  data-case-counter
                  aria-live="polite"
                  aria-atomic="true"
                  >1/4</span
                >
                <div class="section-two__controls">
                  <button
                    class="section-two__arrow section-two__arrow--prev"
                    type="button"
                    data-case-prev
                    aria-label="Previous case study"
                  >
                    <span aria-hidden="true">&#8592;</span>
                  </button>
                  <button
                    class="section-two__arrow section-two__arrow--next"
                    type="button"
                    data-case-next
                    aria-label="Next case study"
                  >
                    <span aria-hidden="true">&#8594;</span>
                  </button>
                </div>
              </div>
            </div>
          </header>

          <div
            class="section-two__grid"
            aria-label="Case studies carousel"
            aria-labelledby="case-studies-heading"
          >
            <article
              class="section-two__case section-two__case--yellow"
              tabindex="0"
              aria-label="Case study 1"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Delivered</span>
                <h3 class="section-two__case-title">
                  Telecom &amp; Fintech · Africa
                </h3>
                <p class="section-two__case-description">
                  A telecom operator needed to launch a super-app across two
                  markets simultaneously — two distinct operating scenarios,
                  multiple stakeholders, under acquisition pressure. We scoped
                  and built the product, structured two distinct go-to-market
                  scenarios — the client chose one and deployed it.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--blue"
              tabindex="0"
              aria-label="Case study 2"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Delivered</span>
                <h3 class="section-two__case-title">
                  Community Marketplace · Africa
                </h3>
                <p class="section-two__case-description">
                  An e-commerce marketplace had to go from zero to a viable
                  market in under two years — positioning, branding,
                  organisation, go-to-market, and building an engaged community
                  of buyers and sellers. We structured and led end-to-end
                  delivery to €1.25M GMV in 18 months.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--white"
              tabindex="0"
              aria-label="Case study 3"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">In progress</span>
                <h3 class="section-two__case-title">
                  Community Cooking · Europe
                </h3>
                <p class="section-two__case-description">
                  A cooking enthusiast wanted to turn daily meal prep into a
                  driver of social connection and savings. We structured a
                  "collective cooking at home" operational model and designed
                  the product experience through a mobile app orchestrating
                  batch cooking sessions — built around a triple gain: 50% cost
                  savings, time efficiency, and wellbeing.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--violet"
              tabindex="0"
              aria-label="Case study 4"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Starting</span>
                <h3 class="section-two__case-title">
                  Agentic Delivery · France
                </h3>
                <p class="section-two__case-description">
                  A French software company needed to scale client deployments
                  without scaling headcount. We are designing a system of
                  autonomous AI agents under human supervision to orchestrate
                  and deliver client projects — from onboarding to go-live.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="section-faq" id="faq" aria-label="FAQ">
        <div class="section-faq__inner">
          <header class="section-faq__intro">
            <h2 class="section-faq__title">Frequently asked questions</h2>
          </header>

          <div class="section-faq__chat" aria-label="FAQ list">
            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-0"
                  id="faq-q-0"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >How do you turn AI into business outcomes?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-0"
                role="region"
                aria-labelledby="faq-q-0"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      AI projects don't fail because of the technology — they
                      fail because no one owns both the business intent and the
                      delivery. Izybiz takes the operational role: we frame the
                      use cases, run the deployment, and make sure results are
                      traceable.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-1"
                  id="faq-q-1"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label">What does this cost?</span>
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-1"
                role="region"
                aria-labelledby="faq-q-1"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      We quote based on your scope. Book a call and we'll give
                      you numbers upfront. Transparency first.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-2"
                  id="faq-q-2"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >What's the timeline to first results?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-2"
                role="region"
                aria-labelledby="faq-q-2"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      You see automations working in 2–3 weeks. Full deployment
                      depends on your systems. Most teams are productive within
                      6–8 weeks.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-3"
                  id="faq-q-3"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Do I need to change my team or my processes?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-3"
                role="region"
                aria-labelledby="faq-q-3"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      No. We adapt to how you work today. If a process is
                      broken, we'll tell you — but we don't impose
                      reorganisation.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-4"
                  id="faq-q-4"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >How do you measure success?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-4"
                role="region"
                aria-labelledby="faq-q-4"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Hours saved per week. Deals closed. Features shipped.
                      Errors reduced. We pick 2–3 metrics that matter to you
                      and track them.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-5"
                  id="faq-q-5"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >What if we need to pivot mid-project?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-5"
                role="region"
                aria-labelledby="faq-q-5"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      We expect changes. Workflows are easy to modify. Pivoting
                      costs time, not extra money.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-6"
                  id="faq-q-6"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Is this customised or template-based?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-6"
                role="region"
                aria-labelledby="faq-q-6"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Both. We start with your specific processes, not generic
                      templates. But we reuse patterns that have proven
                      themselves.
                    </p>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>

    </main>

    <!-- Book a demo modal -->
    <div
      class="demo-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="demo-modal-title"
      aria-describedby="demo-modal-description"
      hidden
    >
      <div class="demo-modal__backdrop" data-demo-modal-close></div>
      <div class="demo-modal__dialog">
        <button
          type="button"
          class="demo-modal__close-button"
          aria-label="Close dialog"
          data-demo-modal-close
        >
          ×
        </button>

        <div class="demo-modal__header">
          <h2 id="demo-modal-title" class="demo-modal__title">Book a call</h2>
          <p id="demo-modal-description" class="demo-modal__description">
            Leave your email and we'll get back to you shortly.
          </p>
        </div>

        <form class="demo-modal__form" novalidate>
          <div class="demo-modal__field">
            <label for="demo-modal-phone" class="demo-modal__label"
              >Phone number</label
            >
            <input
              id="demo-modal-phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              required
              class="demo-modal__input"
              placeholder="+33 6 12 34 56 78"
            />
          </div>

          <div class="demo-modal__field">
            <label for="demo-modal-email" class="demo-modal__label"
              >Email</label
            >
            <input
              id="demo-modal-email"
              name="email"
              type="email"
              inputmode="email"
              autocomplete="email"
              required
              class="demo-modal__input"
              placeholder="you@company.com"
            />
          </div>

          <p class="demo-modal__message" aria-live="polite"></p>

          <button
            type="submit"
            class="hero-izybiz__button demo-modal__submit-button"
          >
            <span class="demo-modal__submit-label">Request a call</span>
            <span class="demo-modal__submit-loading" aria-hidden="true">
              Loading…
            </span>
          </button>
        </form>

        <div class="demo-modal__success" hidden>
          <h2 class="demo-modal__success-title">Email saved</h2>
          <p class="demo-modal__success-description">
            Thanks! We've saved your email. You'll receive a confirmation email
            shortly.
          </p>
          <button
            type="button"
            class="hero-izybiz__button demo-modal__success-close"
            data-demo-modal-close
          >
            Close
          </button>
        </div>
      </div>
    </div>
