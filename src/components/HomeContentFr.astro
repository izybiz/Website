---
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog-fr"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<main class="page-shell">
      <section class="section-one" aria-label="Section 1">
        <div class="hero-izybiz">
          <div class="hero-izybiz__text">
            <h1 class="hero-izybiz__title">
              <span class="hero-izybiz__title-line"
                >Izybiz est une plateforme d'agents IA pour dirigeants.</span
              >
            </h1>
            <p class="hero-izybiz__subtitle">
              <span>
                Vous restez le patron, votre équipe d'agents fait le travail.
              </span>
            </p>
          </div>

          <div class="hero-izybiz__actions">
            <a class="hero-izybiz__button" href="#prendre-contact">
              Rejoindre la bêta privée
            </a>
            <a
              class="hero-izybiz__button hero-izybiz__button--secondary"
              href="#comment-ca-marche"
            >
              Comment ça marche ?
            </a>
          </div>

          <p class="hero-izybiz__beta-badge hero-izybiz__beta-badge--intro" hidden>
            <span class="hero-izybiz__beta-text">
              <span class="hero-izybiz__beta-text-line">Bêta privée en préparation.</span>
              <span class="hero-izybiz__beta-text-line">Accès sur invitation.</span>
            </span>
          </p>
        </div>

        <section class="home-ai" id="comment-ca-marche" aria-labelledby="home-ai-title">
          <div class="home-ai__inner">
            <h2 class="home-ai__title" id="home-ai-title">
              Trois étapes.<br> Pas de configuration.
            </h2>

          <div class="we-deliver__cards-row" aria-label="Ce qu’on délivre cards">
            <article
              class="we-deliver__card we-deliver__card--dna"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--dna"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--dna.svg"
                    alt=""
                  />
                </div>
                <div
                  class="we-deliver__card-content we-deliver__card-content--dna"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--dna"
                  >
                    1. VOUS BRIEFEZ
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--dna"
                    aria-label="Your DNA deliverables"
                  >
                    <span class="we-deliver__card-tab">Langage naturel</span>
                    <span class="we-deliver__card-tab">Cadrage en 1 question</span>
                    <span class="we-deliver__card-tab">Délégation immédiate</span>
                    <span class="we-deliver__card-tab">Workflow généré</span>
                    <span class="we-deliver__card-tab">Gain de temps immédiat</span>
                  </div>
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--agent"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--agent"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--agent"
                  >
                    2. L'ÉQUIPE SE CRÉE
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--agent"
                    aria-label="Agent Factory deliverables"
                  >
                    <span class="we-deliver__card-tab">Décomposition automatique</span>
                    <span class="we-deliver__card-tab">Sélection des agents</span>
                    <span class="we-deliver__card-tab">Orchestration en temps réel</span>
                    <span class="we-deliver__card-tab">Organigramme visible</span>
                    <span class="we-deliver__card-tab">Coordination autonome</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--agent"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--agent.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--output"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--output"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--output"
                  >
                    3. VOUS PILOTEZ
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--output"
                    aria-label="Customer ready output deliverables"
                  >
                    <span class="we-deliver__card-tab">Livrable structuré</span>
                    <span class="we-deliver__card-tab">Validation immédiate</span>
                    <span class="we-deliver__card-tab">Correction ou relance</span>
                    <span class="we-deliver__card-tab">Apprentissage continu</span>
                    <span class="we-deliver__card-tab">Contrôle total conservé</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--output"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--output.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>
          </div>

          </div>
        </section>

        <section class="home-why" aria-labelledby="home-why-title" data-home-why>
          <div class="home-why__inner">
            <div class="home-why__layout">
              <div class="home-why__content" data-home-why-content>
                <h2 class="home-why__title" id="home-why-title">Pourquoi Izybiz ?</h2>

                <div class="home-why__grid" aria-label="Points clés Izybiz" data-home-why-grid>
                  <div class="home-why__progress" aria-hidden="true">
                    <span class="home-why__progress-track"></span>
                    <span class="home-why__progress-fill"></span>
                  </div>
                  <article class="home-why__card" data-home-why-card data-home-why-index="0">
                    <div class="home-why__card-copy">
                      <h3 class="home-why__card-title">Une équipe, <span class="home-why__card-highlight home-why__card-highlight--orange">pas un assistant</span></h3>
                      <p class="home-why__card-text">
                        Un agent solo plafonne vite. Izybiz orchestre des agents spécialisés qui se répartissent la mission.
                      </p>
                    </div>
                  </article>

                  <article class="home-why__card" data-home-why-card data-home-why-index="1">
                    <div class="home-why__card-copy">
                      <h3 class="home-why__card-title">Un brief, <span class="home-why__card-highlight home-why__card-highlight--yellow">pas un workflow</span></h3>
                      <p class="home-why__card-text">
                        Vous décrivez la mission en langage naturel. Pas de connecteurs à câbler, pas de logique à dessiner.
                      </p>
                    </div>
                  </article>

                  <article class="home-why__card" data-home-why-card data-home-why-index="2">
                    <div class="home-why__card-copy">
                      <h3 class="home-why__card-title">Multi-providers, <span class="home-why__card-highlight home-why__card-highlight--blue">zéro lock-in</span></h3>
                      <p class="home-why__card-text">
                        Requêtes anonymisées et réparties entre plusieurs modèles. Vos données métier restent les vôtres.
                      </p>
                    </div>
                  </article>
                </div>
              </div>

              <div class="home-why__video">
                <video class="home-why__video-media" controls preload="metadata" muted playsinline loop>
                  <source src="/assets/Anim-Izybiz-V2.mp4" type="video/mp4" />
                  Votre navigateur ne supporte pas la balise vidéo.
                </video>
              </div>
            </div>
          </div>
        </section>

        <section class="home-contact-block" id="prendre-contact" aria-label="Prendre contact">
          <p class="hero-izybiz__beta-badge">BÊTA PRIVÉE • ACCÈS SUR INVITATION</p>
          <h2 class="section-contact__title">Soyez parmi les premiers</h2>
          <div class="article-page__body home-contact-block__body">
            <form
              class="contact-form"
              method="POST"
              action="https://api.web3forms.com/submit"
            >
              <input type="hidden" name="access_key" value="ae024e50-5c9a-418c-9a35-0572c0dea506" />
              <input type="hidden" name="subject" value="[izybiz.fr] Nouveau contact" />
              <input type="hidden" name="redirect" value="https://izybiz.fr/contact/merci/" />
              <input type="checkbox" name="botcheck" style="display: none;" />

              <div class="contact-form__field contact-form__field--nom">
                <label class="contact-form__label" for="nom-home">Nom *</label>
                <input class="contact-form__input" type="text" id="nom-home" name="nom" placeholder="Prénom Nom" required />
              </div>

              <div class="contact-form__field contact-form__field--email">
                <label class="contact-form__label" for="email-home">Email *</label>
                <input class="contact-form__input" type="email" id="email-home" name="email" placeholder="votre@email.com" required />
              </div>

              <button class="contact-form__submit" type="submit">Envoyer</button>
            </form>
          </div>
          <div
            class="contact-feedback-modal"
            data-contact-feedback-modal
            role="dialog"
            aria-modal="true"
            aria-labelledby="contact-feedback-title"
            aria-describedby="contact-feedback-message"
            hidden
          >
            <div class="contact-feedback-modal__backdrop" data-contact-feedback-close></div>
            <div class="contact-feedback-modal__panel">
              <h3 class="contact-feedback-modal__title" id="contact-feedback-title"></h3>
              <p class="contact-feedback-modal__message" id="contact-feedback-message"></p>
              <button
                type="button"
                class="contact-form__submit contact-feedback-modal__button"
                data-contact-feedback-close
              >
                Fermer
              </button>
            </div>
          </div>
        </section>

        <section class="home-insights" aria-label="Insights">
          <div class="home-insights__inner">
            <div class="home-insights__header">
              <div class="home-insights__header-left">
                <p class="home-insights__eyebrow">Insight</p>
                <h2 class="home-insights__title">Ce qu'on apprend<br>en conditions réelles.</h2>
              </div>
            </div>
            <ul class="home-insights__grid">
              <li class="home-insights__card">
                <a class="home-insights__card-link" href="/blog/pipeline-editorial-automatise-ia-2026-04-13/">
                  <time class="home-insights__card-date">13 avril 2026</time>
                  <div class="home-insights__card-content">
                    <h3 class="home-insights__card-title">Pipeline éditorial automatisé : ce que ça produit vraiment</h3>
                    <p class="home-insights__card-desc">4 couches, agents spécialisés, quality gate, publication trilingue. Retour d'une mise en place en mission.</p>
                  </div>
                  <span class="home-insights__card-tag">Lire l'article</span>
                </a>
              </li>
              <li class="home-insights__card">
                <a class="home-insights__card-link" href="/blog/github-spec-kit-specification-agent-ia-2025-11-15/">
                  <time class="home-insights__card-date">15 novembre 2025</time>
                  <div class="home-insights__card-content">
                    <h3 class="home-insights__card-title">GitHub Spec-Kit : /specify, /plan, /tasks pour votre agent IA</h3>
                    <p class="home-insights__card-desc">Vos agents IA dévient de votre intention ? Le spec-kit transforme votre besoin en spécification exécutable en 3 commandes.</p>
                  </div>
                  <span class="home-insights__card-tag">Lire l'article</span>
                </a>
              </li>
              <li class="home-insights__card">
                <a class="home-insights__card-link" href="/blog/bmad-method-agents-specialises-vibe-coding-2025-07-08/">
                  <time class="home-insights__card-date">8 juillet 2025</time>
                  <div class="home-insights__card-content">
                    <h3 class="home-insights__card-title">BMAD Method : agents spécialisés pour livrer ce que vous avez spécifié</h3>
                    <p class="home-insights__card-desc">Le vibe coding produit du code vite, rarement ce que vous vouliez. La BMAD method impose des agents spécialisés avec artefacts structurés.</p>
                  </div>
                  <span class="home-insights__card-tag">Lire l'article</span>
                </a>
              </li>
            </ul>
          </div>
        </section>

      </section>

    </main>

    <!-- Book a demo modal -->
    <div
      class="demo-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="demo-modal-title"
      aria-describedby="demo-modal-description"
      hidden
    >
      <div class="demo-modal__backdrop" data-demo-modal-close></div>
      <div class="demo-modal__dialog">
        <button
          type="button"
          class="demo-modal__close-button"
          aria-label="Fermer dialogue"
          data-demo-modal-close
        >
          ×
        </button>

        <div class="demo-modal__header">
          <h2 id="demo-modal-title" class="demo-modal__title">Prendre contact</h2>
          <p id="demo-modal-description" class="demo-modal__description">
            Laissez votre email et nous revenons vers vous rapidement.
          </p>
        </div>

        <form class="demo-modal__form" novalidate>
          <div class="demo-modal__field">
            <label for="demo-modal-phone" class="demo-modal__label"
              >Numéro de téléphone</label
            >
            <input
              id="demo-modal-phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              required
              class="demo-modal__input"
              placeholder="+33 6 12 34 56 78"
            />
          </div>

          <div class="demo-modal__field">
            <label for="demo-modal-email" class="demo-modal__label"
              >Email</label
            >
            <input
              id="demo-modal-email"
              name="email"
              type="email"
              inputmode="email"
              autocomplete="email"
              required
              class="demo-modal__input"
              placeholder="you@company.com"
            />
          </div>

          <p class="demo-modal__message" aria-live="polite"></p>

          <button
            type="submit"
            class="hero-izybiz__button demo-modal__submit-button"
          >
            <span class="demo-modal__submit-label">Demander un appel</span>
            <span class="demo-modal__submit-loading" aria-hidden="true">
              Chargement...
            </span>
          </button>
        </form>

        <div class="demo-modal__success" hidden>
          <h2 class="demo-modal__success-title">Email enregistré</h2>
          <p class="demo-modal__success-description">
            Merci ! Votre email a bien été enregistré. Vous recevrez un email de confirmation
            sous peu.
          </p>
          <button
            type="button"
            class="hero-izybiz__button demo-modal__success-close"
            data-demo-modal-close
          >
            Fermer
          </button>
        </div>
      </div>
    </div>
