---
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog-fr"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<main class="page-shell">
      <section class="section-one" aria-label="Section 1">
        <div class="hero-izybiz">
          <div class="hero-izybiz__text">
            <h1 class="hero-izybiz__title">
              <span class="hero-izybiz__title-line"
                >Management de transition et IA <br />
                pour vos opérations</span
              >
            </h1>
            <p class="hero-izybiz__subtitle">
              <span>
                Management de transition et intégration IA pour remettre les priorités sous contrôle, accélérer l’exécution et produire des résultats mesurables.
              </span>
            </p>
          </div>

          <div class="hero-izybiz__actions">
            <a class="hero-izybiz__button" href="/contact/">
              Prendre contact
            </a>
            <a
              class="hero-izybiz__button hero-izybiz__button--secondary"
              href="https://www.linkedin.com/company/izybiz/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Ouvrir la page LinkedIn d'IZYBIZ dans un nouvel onglet"
            >
              Envoyer un message LinkedIn
            </a>
          </div>
        </div>

        <section class="hero-metrics" aria-label="Key performance highlights">
          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="95">0%</p>
            <p class="hero-metrics__description">
              Taux d'échec des projets d'IA générative en entreprise.
            </p>
          </article>

          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="23">0%</p>
            <p class="hero-metrics__description">
              Seulement 23 % des dirigeants peuvent relier leurs investissements IA
              à un résultat financier mesurable.
            </p>
          </article>

          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="84">0%</p>
            <p class="hero-metrics__description">
              84 % des échecs d'IA sont dus à une mauvaise gestion, pas à la
              technologie en elle-même.
            </p>
          </article>
        </section>

        <section class="home-transition" aria-labelledby="home-transition-title">
          <div class="home-transition__intro">
            <h2 class="home-transition__title" id="home-transition-title">
              <span class="home-transition__title-line">Management de transition</span>
              <span class="home-transition__title-line">pour les phases critiques</span>
            </h2>
            <p class="home-transition__description">
              Quand une activité dérive, qu’un projet stratégique ralentit ou qu’une transformation doit produire vite, il faut plus qu’un cadrage. Il faut une direction opérationnelle capable de reprendre la main, fixer les priorités et tenir l’exécution.
            </p>
            <a class="home-transition__more" href="/management-de-transition/">Notre approche management de transition</a>
          </div>

          <ul class="blog-list home-transition__posts" aria-label="Derniers articles">
            {latestPosts.map((post) => {
              const slug = post.id.replace(/\.md$/, "");
              const date = post.data.pubDate.toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" });

              return (
                <li class="blog-card">
                  <a class="blog-card__link" href={`/blog/${slug}/`}>
                    <time class="blog-card__date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                    <div class="blog-card__content">
                      <h3 class="blog-card__title">{post.data.title}</h3>
                      <p class="blog-card__description">{post.data.description}</p>
                    </div>
                    <span class="blog-card__cta">Lire l'article</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>

        <section class="home-ai" aria-labelledby="home-ai-title">
          <div class="home-ai__inner">
            <h2 class="home-ai__title" id="home-ai-title">
              Intégrer l’IA sans perdre le contrôle opérationnel
            </h2>
            <p class="home-ai__description">
              L’IA crée de la valeur lorsqu’elle s’inscrit dans des priorités claires, des processus tenus et des responsabilités explicites.
            </p>
            <a class="home-ai__more" href="/integration-ia/">Notre approche intégration IA en entreprise</a>
          </div>
          <section class="hero-video" aria-label="Izybiz showcase video">
            <video class="hero-video__media" controls preload="metadata">
              <source src="/assets/Anim-Izybiz-V2.mp4" type="video/mp4" />
              Votre navigateur ne prend pas en charge la balise vidéo.
            </video>
          </section>
        </section>

        <section
          class="we-deliver"
          id="we-deliver"
          aria-labelledby="we-deliver-title"
        >
          <div class="we-deliver__intro">
            <h2 class="we-deliver__title" id="we-deliver-title">
              Des résultats mesurables, pas des recommandations de principe
            </h2>
            <p class="we-deliver__intro-copy">
              Une mission utile se juge sur ce qu’elle change dans les opérations, pas sur la qualité des slides. Dès le démarrage, nous clarifions les objectifs, les indicateurs à suivre et les chantiers à prioriser. L’enjeu est simple : produire des effets visibles, lisibles et mesurables.
            </p>
          </div>

          <div class="we-deliver__cards-row" aria-label="Ce qu'on délivre cards">
            <article
              class="we-deliver__card we-deliver__card--dna"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--dna"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--dna.svg"
                    alt=""
                  />
                </div>
                <div
                  class="we-deliver__card-content we-deliver__card-content--dna"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--dna"
                  >
                    CE QUE VOUS APPORTEZ
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--dna"
                    aria-label="Your DNA deliverables"
                  >
                    <span class="we-deliver__card-tab">Objectifs business</span>
                    <span class="we-deliver__card-tab">Processus clés</span>
                    <span class="we-deliver__card-tab">Contraintes</span>
                    <span class="we-deliver__card-tab">Exigences</span>
                    <span class="we-deliver__card-tab">Équipes internes</span>
                    <span class="we-deliver__card-tab">Outils existants</span>
                  </div>
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--agent"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--agent"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--agent"
                  >
                    CE QUE NOUS STRUCTURONS
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--agent"
                    aria-label="Agent Factory deliverables"
                  >
                    <span class="we-deliver__card-tab">Cadrage des cas d'usage</span>
                    <span class="we-deliver__card-tab">Sélection des fournisseurs</span>
                    <span class="we-deliver__card-tab">Choix technologique</span>
                    <span class="we-deliver__card-tab">Workflow IA</span>
                    <span class="we-deliver__card-tab">Points de contrôle humains</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--agent"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--agent.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--output"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--output"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--output"
                  >
                    CE QUE VOUS POSSÉDEZ
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--output"
                    aria-label="Customer ready output deliverables"
                  >
                    <span class="we-deliver__card-tab">Système IA opérationnel</span>
                    <span
                      class="we-deliver__card-tab we-deliver__card-tab--output-workflow"
                      >Workflows documentés</span
                    >
                    <span class="we-deliver__card-tab">Équipe formée</span>
                    <span class="we-deliver__card-tab"
                      >Responsabilités claires</span
                    >
                    <span class="we-deliver__card-tab">Autonomie complète</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--output"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--output.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>
          </div>
          <div class="we-deliver__services-link">
            <a href="/services/">Voir toutes nos missions</a>
          </div>
        </section>
      </section>

      <section class="section-two" id="we-do" aria-label="Case studies">
        <div class="section-two__inner">
          <header class="section-two__intro">
            <h2 class="section-two__title" id="case-studies-heading">
              Nos dernières missions
            </h2>
            <div
              class="section-two__topbar"
              aria-label="Case studies navigation"
            >
              <div
                class="section-two__tabs"
                role="tablist"
                aria-label="Case studies tabs"
                data-case-tablist
              >
                <button
                  class="section-two__tab is-active"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Telecom &amp; Fintech · Afrique
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Marketplace communautaire · Afrique
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Cuisine communautaire · Europe
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Delivery agentique · France
                </button>
              </div>

              <div class="section-two__mobile-nav">
                <span
                  class="section-two__counter"
                  data-case-counter
                  aria-live="polite"
                  aria-atomic="true"
                  >1/4</span
                >
                <div class="section-two__controls">
                  <button
                    class="section-two__arrow section-two__arrow--prev"
                    type="button"
                    data-case-prev
                    aria-label="Cas précédent"
                  >
                    <span aria-hidden="true">&#8592;</span>
                  </button>
                  <button
                    class="section-two__arrow section-two__arrow--next"
                    type="button"
                    data-case-next
                    aria-label="Cas suivant"
                  >
                    <span aria-hidden="true">&#8594;</span>
                  </button>
                </div>
              </div>
            </div>
          </header>

          <div
            class="section-two__grid"
            aria-label="Case studies carousel"
            aria-labelledby="case-studies-heading"
          >
            <article
              class="section-two__case section-two__case--yellow"
              tabindex="0"
              aria-label="Case study 1"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Livré</span>
                <h3 class="section-two__case-title">
                  Telecom &amp; Fintech · Afrique
                </h3>
                <p class="section-two__case-description">
                  Un opérateur telecom devait lancer une super-app sur deux marchés
                  en même temps : deux scénarios opérationnels distincts, de
                  nombreuses parties prenantes et pression de cession. Nous avons
                  défini et construit le produit, structuré deux scénarios de
                  go-to-market distincts — le client en a choisi un et l'a déployé.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--blue"
              tabindex="0"
              aria-label="Case study 2"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Livré</span>
                <h3 class="section-two__case-title">
                  Marketplace communautaire · Afrique
                </h3>
                <p class="section-two__case-description">
                  Une marketplace e-commerce devait passer de zéro à un marché
                  viable en moins de deux ans : positionnement, marque,
                  organisation, go-to-market et construction d'une communauté
                  active d'acheteurs et de vendeurs. Nous avons structuré et
                  piloté la livraison de bout en bout jusqu'à 1,25 M€ de GMV en
                  18 mois.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--white"
              tabindex="0"
              aria-label="Case study 3"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">En cours</span>
                <h3 class="section-two__case-title">
                  Cuisine communautaire · Europe
                </h3>
                <p class="section-two__case-description">
                  Une passionnée de cuisine voulait faire de la préparation
                  quotidienne des repas un levier de lien social et d'économies.
                  Nous avons structuré un modèle opérationnel de « cuisine
                  collective à domicile » et conçu l'expérience produit via une
                  application mobile qui orchestre des sessions de batch cooking
                  autour d'un triple gain : 50 % d'économies, gain de temps et
                  bien-être.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--violet"
              tabindex="0"
              aria-label="Case study 4"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Démarrage</span>
                <h3 class="section-two__case-title">
                  Delivery agentique · France
                </h3>
                <p class="section-two__case-description">
                  Un éditeur logiciel français devait fiabiliser les
                  déploiements clients sans augmenter les effectifs. Nous
                  concevons un système d'agents IA autonomes supervisés par
                  l'humain pour orchestrer et livrer les projets clients — de
                  l'onboarding à la mise en production.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="section-faq" id="faq" aria-label="FAQ">
        <div class="section-faq__inner">
          <header class="section-faq__intro">
            <h2 class="section-faq__title">Questions fréquentes</h2>
          </header>

          <div class="section-faq__chat" aria-label="FAQ list">
            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-0"
                  id="faq-q-0"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Comment on transforme l'IA en résultats business ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-0"
                role="region"
                aria-labelledby="faq-q-0"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Izybiz repose sur une idée simple : les projets d'IA ne
                      échouent pas à cause de la technologie, mais parce que
                      personne ne porte à la fois l'intention business et la
                      livraison. Forts de 20 ans de management, nous faisons en
                      sorte que les solutions IA soient déployées, adoptées et
                      produisent des résultats business concrets.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-1"
                  id="faq-q-1"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label">Combien ça coûte ?</span>
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-1"
                role="region"
                aria-labelledby="faq-q-1"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Nous estimons en fonction de votre périmètre. Prenez
                      rendez-vous : nous vous donnerons des chiffres dès le
                      départ. La transparence avant tout.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-2"
                  id="faq-q-2"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Quel délai pour les premiers résultats ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-2"
                role="region"
                aria-labelledby="faq-q-2"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Vous voyez des automatisations en marche en 2 à 3 semaines.
                      Le déploiement complet dépend de vos systèmes. La plupart
                      des équipes sont productives en 6 à 8 semaines.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-3"
                  id="faq-q-3"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Dois-je changer mon équipe ou mes processus ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-3"
                role="region"
                aria-labelledby="faq-q-3"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Non. Nous nous adaptons à votre façon de travailler
                      aujourd'hui. Si votre process est cassé, nous vous le
                      dirons. Mais nous n'imposons pas de réorganisation.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-4"
                  id="faq-q-4"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Comment mesurez-vous le succès ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-4"
                role="region"
                aria-labelledby="faq-q-4"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Heures gagnées par semaine. Affaires conclues. Fonctionnalités
                      livrées. Erreurs réduites. Nous choisissons 2 à 3 métriques
                      qui comptent pour vous et nous les suivons.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-5"
                  id="faq-q-5"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Que faire si nous devons pivoter en cours de projet ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-5"
                role="region"
                aria-labelledby="faq-q-5"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Nous anticipons les changements. Les workflows sont faciles
                      à modifier. Pivoter coûte du temps, pas d'argent
                      supplémentaire.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-6"
                  id="faq-q-6"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >Est-ce personnalisé ou basé sur des templates ?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-6"
                role="region"
                aria-labelledby="faq-q-6"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Les deux. Nous partons de vos processus concrets, pas de
                      gabarits génériques. Mais nous réutilisons des patterns qui
                      ont fait leurs preuves.
                    </p>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>

    </main>

    <!-- Book a demo modal -->
    <div
      class="demo-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="demo-modal-title"
      aria-describedby="demo-modal-description"
      hidden
    >
      <div class="demo-modal__backdrop" data-demo-modal-close></div>
      <div class="demo-modal__dialog">
        <button
          type="button"
          class="demo-modal__close-button"
          aria-label="Fermer dialogue"
          data-demo-modal-close
        >
          ×
        </button>

        <div class="demo-modal__header">
          <h2 id="demo-modal-title" class="demo-modal__title">Prendre contact</h2>
          <p id="demo-modal-description" class="demo-modal__description">
            Laissez votre email et nous revenons vers vous rapidement.
          </p>
        </div>

        <form class="demo-modal__form" novalidate>
          <div class="demo-modal__field">
            <label for="demo-modal-phone" class="demo-modal__label"
              >Numéro de téléphone</label
            >
            <input
              id="demo-modal-phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              required
              class="demo-modal__input"
