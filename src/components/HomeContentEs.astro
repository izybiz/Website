---
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog-es"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<main class="page-shell">
      <section class="section-one" aria-label="Section 1">
        <div class="hero-izybiz">
          <div class="hero-izybiz__text">
            <h1 class="hero-izybiz__title">
              <span class="hero-izybiz__title-line"
                >Hacer la IA eficaz donde <br />
                importa: en tus operaciones</span
              >
            </h1>
            <p class="hero-izybiz__subtitle">
              <span>
                Management de transición e integración de IA para recuperar el control de las prioridades, acelerar la ejecución y lograr resultados medibles.
              </span>
            </p>
          </div>

          <div class="hero-izybiz__actions">
            <a class="hero-izybiz__button" href="/es/contacto/">
              Reservar una llamada
            </a>
            <a
              class="hero-izybiz__button hero-izybiz__button--secondary"
              href="https://www.linkedin.com/company/izybiz/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Abrir la página de LinkedIn de IZYBIZ en una nueva pestaña"
            >
              Enviar mensaje en LinkedIn
            </a>
          </div>
        </div>

        <section class="hero-metrics" aria-label="Key performance highlights">
          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="95">0%</p>
            <p class="hero-metrics__description">
              Tasa de fracaso de proyectos de IA generativa en empresas.
            </p>
          </article>

          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="23">0%</p>
            <p class="hero-metrics__description">
              Solo el 23 % de los directivos puede vincular sus inversiones en IA
              con un resultado financiero medible.
            </p>
          </article>

          <article class="hero-metrics__item">
            <p class="hero-metrics__title" data-count-to="84">0%</p>
            <p class="hero-metrics__description">
              El 84 % de los fracasos en IA se debe a una mala gestión, no a la
              tecnología en sí.
            </p>
          </article>
        </section>

        <section class="home-transition" aria-labelledby="home-transition-title">
          <div class="home-transition__intro">
            <h2 class="home-transition__title" id="home-transition-title">
              Management de transición<br class="home-transition__title-break" />para las fases críticas
            </h2>
            <p class="home-transition__description">
              Cuando una actividad se desvía, un proyecto estratégico se ralentiza o una transformación tiene que producir resultados rápido, un marco de trabajo no basta. Hace falta una dirección operacional capaz de tomar las riendas, fijar las prioridades y mantener la ejecución.
            </p>
            <a class="home-transition__more" href="/es/gestion-transicion/">Nuestro enfoque de management de transición</a>
          </div>

          <ul class="blog-list home-transition__posts" aria-label="Últimos artículos">
            {latestPosts.map((post) => {
              const slug = post.id.replace(/\.md$/, "");
              const date = post.data.pubDate.toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });

              return (
                <li class="blog-card">
                  <a class="blog-card__link" href={`/es/blog/${slug}/`}>
                    <time class="blog-card__date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                    <div class="blog-card__content">
                      <h3 class="blog-card__title">{post.data.title}</h3>
                      <p class="blog-card__description">{post.data.description}</p>
                    </div>
                    <span class="blog-card__cta">Leer el artículo</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>

        <section class="home-ai" aria-labelledby="home-ai-title">
          <div class="home-ai__inner">
            <h2 class="home-ai__title" id="home-ai-title">
              Integrar la IA sin perder el control operacional
            </h2>
            <p class="home-ai__description">
              La IA crea valor cuando se inscribe en prioridades claras, procesos controlados y responsabilidades explícitas.
            </p>
            <a class="home-ai__more" href="/es/integracion-ia/">Nuestro enfoque de integración de IA en empresas</a>
          </div>
          <section class="hero-video" aria-label="Izybiz showcase video">
            <video class="hero-video__media" controls preload="metadata">
              <source src="/assets/Anim-Izybiz-V2.mp4" type="video/mp4" />
              Tu navegador no soporta la etiqueta de video.
            </video>
          </section>
        </section>

        <section
          class="we-deliver"
          id="we-deliver"
          aria-labelledby="we-deliver-title"
        >
          <div class="we-deliver__intro">
            <h2 class="we-deliver__title" id="we-deliver-title">
              Resultados medibles, no recomendaciones de principio
            </h2>
            <p class="we-deliver__intro-copy">
              Una misión útil se juzga por lo que cambia en las operaciones, no por la calidad de las presentaciones. Desde el inicio, clarificamos los objetivos, los indicadores a seguir y los proyectos a priorizar. El objetivo es simple: producir efectos visibles, legibles y medibles.
            </p>
          </div>

          <div class="we-deliver__cards-row" aria-label="Qué entregamos cards">
            <article
              class="we-deliver__card we-deliver__card--dna"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--dna"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--dna.svg"
                    alt=""
                  />
                </div>
                <div
                  class="we-deliver__card-content we-deliver__card-content--dna"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--dna"
                  >
                    LO QUE TÚ APORTAS
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--dna"
                    aria-label="Your DNA deliverables"
                  >
                    <span class="we-deliver__card-tab">Objetivos de negocio</span>
                    <span class="we-deliver__card-tab">Procesos clave</span>
                    <span class="we-deliver__card-tab">Restricciones</span>
                    <span class="we-deliver__card-tab">Requisitos</span>
                    <span class="we-deliver__card-tab">Equipos internos</span>
                    <span class="we-deliver__card-tab">Herramientas existentes</span>
                  </div>
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--agent"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--agent"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--agent"
                  >
                    LO QUE ESTRUCTURAMOS
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--agent"
                    aria-label="Agent Factory deliverables"
                  >
                    <span class="we-deliver__card-tab">Definición de casos de uso</span>
                    <span class="we-deliver__card-tab">Selección de proveedores</span>
                    <span class="we-deliver__card-tab">Elección tecnológica</span>
                    <span class="we-deliver__card-tab">Flujo de trabajo IA</span>
                    <span class="we-deliver__card-tab">Controles humanos</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--agent"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--agent.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>

            <article
              class="we-deliver__card we-deliver__card--output"
              tabindex="0"
            >
              <div class="we-deliver__card-inner">
                <div
                  class="we-deliver__card-content we-deliver__card-content--output"
                >
                  <h3
                    class="we-deliver__card-title we-deliver__card-title--output"
                  >
                    LO QUE POSEES
                  </h3>
                  <div
                    class="we-deliver__card-tabs we-deliver__card-tabs--output"
                    aria-label="Customer ready output deliverables"
                  >
                    <span class="we-deliver__card-tab">Sistema de IA en marcha</span>
                    <span
                      class="we-deliver__card-tab we-deliver__card-tab--output-workflow"
                      >Flujos documentados</span
                    >
                    <span class="we-deliver__card-tab">Equipo capacitado</span>
                    <span class="we-deliver__card-tab"
                      >Responsabilidades claras</span
                    >
                    <span class="we-deliver__card-tab">Independencia total</span>
                  </div>
                </div>
                <div
                  class="we-deliver__card-illustration we-deliver__card-illustration--output"
                  aria-hidden="true"
                >
                  <img
                    class="we-deliver__illustration-image"
                    src="/assets/illustration--output.svg"
                    alt=""
                  />
                </div>
              </div>
            </article>
          </div>
          <div class="we-deliver__services-link">
            <a href="/es/servicios/">Ver todas nuestras misiones</a>
          </div>
        </section>
      </section>

      <section class="section-two" id="we-do" aria-label="Case studies">
        <div class="section-two__inner">
          <header class="section-two__intro">
            <h2 class="section-two__title" id="case-studies-heading">
              Nuestras últimas misiones
            </h2>
            <div
              class="section-two__topbar"
              aria-label="Case studies navigation"
            >
              <div
                class="section-two__tabs"
                role="tablist"
                aria-label="Case studies tabs"
                data-case-tablist
              >
                <button
                  class="section-two__tab is-active"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Telecom y Fintech · África
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Marketplace comunitario · África
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Cocina comunitaria · Europa
                </button>
                <button
                  class="section-two__tab"
                  type="button"
                  role="tab"
                  data-case-tab
                >
                  Entrega agéntica · Francia
                </button>
              </div>

              <div class="section-two__mobile-nav">
                <span
                  class="section-two__counter"
                  data-case-counter
                  aria-live="polite"
                  aria-atomic="true"
                  >1/4</span
                >
                <div class="section-two__controls">
                  <button
                    class="section-two__arrow section-two__arrow--prev"
                    type="button"
                    data-case-prev
                    aria-label="Caso anterior"
                  >
                    <span aria-hidden="true">&#8592;</span>
                  </button>
                  <button
                    class="section-two__arrow section-two__arrow--next"
                    type="button"
                    data-case-next
                    aria-label="Siguiente caso"
                  >
                    <span aria-hidden="true">&#8594;</span>
                  </button>
                </div>
              </div>
            </div>
          </header>

          <div
            class="section-two__grid"
            aria-label="Case studies carousel"
            aria-labelledby="case-studies-heading"
          >
            <article
              class="section-two__case section-two__case--yellow"
              tabindex="0"
              aria-label="Case study 1"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Entregado</span>
                <h3 class="section-two__case-title">
                  Telecom y Fintech · África
                </h3>
                <p class="section-two__case-description">
                  Un operador de telecom necesitaba lanzar una superapp en dos
                  mercados al mismo tiempo: dos escenarios operativos distintos,
                  múltiples partes interesadas y presión de adquisición.
                  Definimos y construimos el producto, estructuramos dos
                  estrategias de salida al mercado — el cliente eligió una y la
                  desplegó.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--blue"
              tabindex="0"
              aria-label="Case study 2"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Entregado</span>
                <h3 class="section-two__case-title">
                  Marketplace comunitario · África
                </h3>
                <p class="section-two__case-description">
                  Un marketplace de e-commerce debía pasar de cero a un mercado
                  viable en menos de dos años: posicionamiento, marca,
                  organización, go-to-market y construcción de una comunidad
                  activa de compradores y vendedores. Estructuramos y lideramos
                  la ejecución de extremo a extremo hasta 1,25 M€ de GMV en 18
                  meses.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--white"
              tabindex="0"
              aria-label="Case study 3"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">En curso</span>
                <h3 class="section-two__case-title">
                  Cocina comunitaria · Europa
                </h3>
                <p class="section-two__case-description">
                  Una apasionada de la cocina quería convertir la preparación
                  diaria de comidas en una fuente de conexión social y ahorro.
                  Estructuramos un modelo operativo de «cocina colectiva en
                  casa» y diseñamos la experiencia de producto mediante una app
                  móvil que orquesta sesiones de batch cooking, con un triple
                  beneficio: 50 % de ahorro, eficiencia de tiempo y bienestar.
                </p>
              </div>
            </article>

            <article
              class="section-two__case section-two__case--violet"
              tabindex="0"
              aria-label="Case study 4"
            >
              <div class="section-two__case-copy">
                <span class="section-two__case-label">Iniciando</span>
                <h3 class="section-two__case-title">
                  Entrega agéntica · Francia
                </h3>
                <p class="section-two__case-description">
                  Una empresa francesa de software necesitaba escalar los
                  despliegues de clientes sin aumentar la plantilla. Estamos
                  diseñando un sistema de agentes de IA autónomos bajo
                  supervisión humana para orquestar y entregar proyectos de
                  clientes, desde el onboarding hasta la puesta en producción.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="section-faq" id="faq" aria-label="FAQ">
        <div class="section-faq__inner">
          <header class="section-faq__intro">
            <h2 class="section-faq__title">Preguntas frecuentes</h2>
          </header>

          <div class="section-faq__chat" aria-label="FAQ list">
            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-0"
                  id="faq-q-0"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >¿Cómo se convierte la IA en resultados de negocio?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-0"
                role="region"
                aria-labelledby="faq-q-0"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Los proyectos de IA no fracasan por la tecnología — fracasan
                      porque nadie asume a la vez la intención de negocio y la
                      entrega. Izybiz toma el rol operacional: definimos los casos
                      de uso, ejecutamos el despliegue y garantizamos que los
                      resultados sean trazables.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-1"
                  id="faq-q-1"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label">¿Cuánto cuesta?</span>
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-1"
                role="region"
                aria-labelledby="faq-q-1"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Presupuestamos según tu alcance. Reserva una llamada y te
                      damos cifras desde el primer momento. La transparencia
                      primero.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-2"
                  id="faq-q-2"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >¿Cuál es el plazo para los primeros resultados?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-2"
                role="region"
                aria-labelledby="faq-q-2"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Verás automatizaciones funcionando en 2–3 semanas. El
                      despliegue completo depende de tus sistemas. La mayoría
                      de equipos son productivos en 6–8 semanas.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-3"
                  id="faq-q-3"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >¿Tengo que cambiar mi equipo o mis procesos?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-3"
                role="region"
                aria-labelledby="faq-q-3"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      No. Nos adaptamos a cómo trabajas hoy. Si un proceso está
                      roto, te lo diremos — pero no imponemos ninguna
                      reorganización.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-4"
                  id="faq-q-4"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >¿Cómo medís el éxito?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-4"
                role="region"
                aria-labelledby="faq-q-4"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Horas ahorradas por semana. Acuerdos cerrados.
                      Funcionalidades lanzadas. Errores reducidos. Elegimos
                      2–3 métricas que te importan y las seguimos.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-5"
                  id="faq-q-5"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >¿Y si necesitamos pivotar durante el proyecto?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-5"
                role="region"
                aria-labelledby="faq-q-5"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Esperamos cambios. Los flujos se modifican fácilmente.
                      Pivotar cuesta tiempo, no dinero extra.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="faq-item" data-faq-item>
              <h3 class="faq-item__heading">
                <button
                  class="faq-item__question"
                  type="button"
                  aria-expanded="false"
                  aria-controls="faq-a-6"
                  id="faq-q-6"
                  data-faq-trigger
                >
                  <span class="faq-item__question-bg" aria-hidden="true"></span>
                  <span class="faq-item__label"
                    >¿Es personalizado o basado en plantillas?</span
                  >
                </button>
              </h3>
              <div
                class="faq-item__answers"
                id="faq-a-6"
                role="region"
                aria-labelledby="faq-q-6"
                data-faq-panel
                hidden
              >
                <div class="faq-item__pad">
                  <div class="faq-item__bubble">
                    <p class="faq-item__answer">
                      Ambos. Partimos de tus procesos específicos, no de
                      plantillas genéricas. Pero reutilizamos patrones que han
                      demostrado funcionar.
                    </p>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>

    </main>

    <!-- Book a demo modal -->
    <div
      class="demo-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="demo-modal-title"
      aria-describedby="demo-modal-description"
      hidden
    >
      <div class="demo-modal__backdrop" data-demo-modal-close></div>
      <div class="demo-modal__dialog">
        <button
          type="button"
          class="demo-modal__close-button"
          aria-label="Cerrar diálogo"
          data-demo-modal-close
        >
          ×
        </button>

        <div class="demo-modal__header">
          <h2 id="demo-modal-title" class="demo-modal__title">Reservar una llamada</h2>
          <p id="demo-modal-description" class="demo-modal__description">
            Déjanos tu correo y te contactaremos en breve.
          </p>
        </div>

        <form class="demo-modal__form" novalidate>
          <div class="demo-modal__field">
            <label for="demo-modal-phone" class="demo-modal__label"
              >Teléfono</label
            >
            <input
              id="demo-modal-phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              required
              class="demo-modal__input"
              placeholder="+33 6 12 34 56 78"
            />
