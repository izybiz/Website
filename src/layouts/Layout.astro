---
import "../styles/global.css";
import {
  defaultLang,
  getLocalizedPath,
  mapPathToLang,
  type Lang,
  useTranslations,
} from "../i18n/translations";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath?: string;
  includeGlobalScript?: boolean;
  ogType?: string;
  ogImage?: string;
  pubDate?: string;
  navType?: "home" | "page";
  alternates?: { fr?: string; en?: string; es?: string };
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath = Astro.url.pathname,
  includeGlobalScript = false,
  ogType = "website",
  ogImage = "https://izybiz.fr/assets/og-default.jpg",
  pubDate,
  navType: navTypeProp,
  alternates,
  noindex = false,
} = Astro.props;

const t = useTranslations(lang);
const cleanPath = canonicalPath.endsWith("/") ? canonicalPath.slice(0, -1) || "/" : canonicalPath;

// Auto-detect nav type
const homePathnames = new Set(["/", "/en", "/en/", "/es", "/es/"]);
const navType = navTypeProp ?? (homePathnames.has(Astro.url.pathname) ? "home" : "page");
const rawPath = canonicalPath || "/";
const canonicalUrl = `https://izybiz.fr${rawPath.endsWith("/") ? rawPath : rawPath + "/"}`;
const localizedAlt = {
  fr: alternates?.fr ?? mapPathToLang(cleanPath, "fr"),
  en: alternates?.en ?? mapPathToLang(cleanPath, "en"),
  es: alternates?.es ?? mapPathToLang(cleanPath, "es"),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-T6W62FCN");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75,200..800&family=Didact+Gothic&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75,200..800&family=Didact+Gothic&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75,200..800&family=Didact+Gothic&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <link rel="icon" href="/assets/fav-icon.png" type="image/png" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={`https://izybiz.fr${localizedAlt.fr}`} />
    <link rel="alternate" hreflang="en" href={`https://izybiz.fr${localizedAlt.en}`} />
    <link rel="alternate" hreflang="es" href={`https://izybiz.fr${localizedAlt.es}`} />
    <link rel="alternate" hreflang="x-default" href={`https://izybiz.fr${localizedAlt.fr}`} />

    <!-- Structured data: Organization (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Izybiz",
      "url": "https://izybiz.fr",
      "logo": "https://izybiz.fr/assets/Logo%20Izybiz.png",
      "sameAs": ["https://www.linkedin.com/company/izybiz/"],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "url": "https://izybiz.fr/contact",
        "availableLanguage": ["French", "English", "Spanish"]
      }
    })} />

    {ogType === "article" && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "url": canonicalUrl,
        ...(pubDate && { "datePublished": pubDate, "dateModified": pubDate }),
        "image": ogImage,
        "author": {
          "@type": "Person",
          "name": "Stéphane Dinepro",
          "url": "https://izybiz.fr/a-propos"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Izybiz",
          "logo": {
            "@type": "ImageObject",
            "url": "https://izybiz.fr/assets/Logo%20Izybiz.png"
          }
        }
      })} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === "fr" ? "fr_FR" : lang === "es" ? "es_ES" : "en_US"} />
    <meta property="og:site_name" content="Izybiz" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body class="intro-stage-1" id="top">
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T6W62FCN" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <header class="site-header" aria-label="Site header">
      <div class="site-header__pill">
        <div class="site-header__identity">
          <a class="site-header__brand" href={getLocalizedPath("home", lang)} aria-label="Go to top">
            <img src="/assets/Logo Izybiz.png" alt="IZYBIZ" width="1479" height="413" />
          </a>
          <div class="site-nav__lang" aria-label="Language switcher">
            <a href={localizedAlt.fr} aria-current={lang === "fr" ? "true" : undefined}>FR</a>
            <span class="site-nav__lang-separator" aria-hidden="true">/</span>
            <a href={localizedAlt.en} aria-current={lang === "en" ? "true" : undefined}>EN</a>
            <span class="site-nav__lang-separator" aria-hidden="true">/</span>
            <a href={localizedAlt.es} aria-current={lang === "es" ? "true" : undefined}>ES</a>
          </div>
        </div>

        <nav class="site-nav" aria-label="Primary">
          <span class="site-nav__links-group">
            <a class="site-nav__link" href={getLocalizedPath("about", lang)}>{t("nav.about")}</a>
            <span class="site-nav__divider" aria-hidden="true"></span>
            <a class="site-nav__link" href={getLocalizedPath("services", lang)}>{t("nav.services")}</a>
            <span class="site-nav__divider" aria-hidden="true"></span>
            <a class="site-nav__link" href={getLocalizedPath("blog", lang)}>{t("nav.blog")}</a>
          </span>
        </nav>

        <div class="site-nav__actions" aria-label="Primary actions">
          <a class="site-nav__button site-nav__button--book" href={getLocalizedPath("contact", lang)} aria-label={t("cta.book")}>
            <!-- Calendar icon -->
            <svg class="site-nav__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="2" y="3.5" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 7.5h14" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 2v3M12 2v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="6" cy="11" r="1" fill="currentColor"/>
              <circle cx="9" cy="11" r="1" fill="currentColor"/>
              <circle cx="12" cy="11" r="1" fill="currentColor"/>
            </svg>
            <span class="site-nav__button-label">{t("cta.book")}</span>
          </a>
          <a
            class="site-nav__button site-nav__button--linkedin"
            href="https://www.linkedin.com/company/izybiz/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn Izybiz"
          >
            <!-- LinkedIn icon -->
            <svg class="site-nav__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="1.5" y="1.5" width="15" height="15" rx="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 7.5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="5" cy="5.5" r="1" fill="currentColor"/>
              <path d="M8.5 13V10c0-1.38 1-2.5 2-2.5s2 .84 2 2.5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M8.5 7.5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        </div>

        <button
          class="site-nav__toggle"
          type="button"
          aria-label="Open menu"
          aria-controls="site-nav-menu"
          aria-expanded="false"
          data-nav-toggle
        >
          <span class="site-nav__toggle-icon" aria-hidden="true"></span>
        </button>
      </div>

      <div class="site-nav__menu" id="site-nav-menu" hidden data-nav-menu>
        <a class="site-nav__menu-link" href={getLocalizedPath("about", lang)}>{t("nav.about")}</a>
        <a class="site-nav__menu-link" href={getLocalizedPath("services", lang)}>{t("nav.services")}</a>
        <a class="site-nav__menu-link" href={getLocalizedPath("blog", lang)}>{t("nav.blog")}</a>
        <a class="site-nav__menu-link" href={getLocalizedPath("contact", lang)}>{t("cta.book")}</a>
        <a
          class="site-nav__menu-link"
          href="https://www.linkedin.com/company/izybiz/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open the IZYBIZ LinkedIn page in a new tab"
        >
          {t("cta.linkedin")}
        </a>
      </div>
    </header>
    <slot />
    <footer class="site-footer" aria-label="Footer">
      <div class="site-footer__inner">
        <div class="site-footer__top">
          <a href={getLocalizedPath("home", lang)} aria-label="Accueil Izybiz">
            <img class="site-footer__logo" src="/assets/Logo Izybiz.png" alt="IZYBIZ" width="1479" height="413" />
          </a>
          <a
            class="site-footer__linkedin"
            href="https://www.linkedin.com/company/izybiz/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn Izybiz"
          >
            <img class="site-footer__linkedin-icon" src="/assets/linkedin-icon.png" alt="LinkedIn" width="980" height="980" />
          </a>
        </div>
        <div class="site-footer__bottom">
          <div class="site-footer__copyright">{t("footer.copyright")}</div>
          <nav class="site-footer__nav" aria-label="Footer navigation">
            <a class="site-footer__nav-link" href={getLocalizedPath("about", lang)}>{t("nav.about")}</a>
            <a class="site-footer__nav-link" href={getLocalizedPath("services", lang)}>{t("nav.services")}</a>
            <a class="site-footer__nav-link" href={getLocalizedPath("blog", lang)}>{t("nav.blog")}</a>
            <a class="site-footer__nav-link" href={getLocalizedPath("contact", lang)}>{t("nav.contact")}</a>
          </nav>
        </div>
      </div>
    </footer>
    <script is:inline>
      window.__IZYBIZ_LANG = "{lang}";
      window.__IZYBIZ_DEFAULT_LANG = "{defaultLang}";
    </script>
    {includeGlobalScript ? <script is:inline src="/script.js"></script> : null}
  </body>
</html>
