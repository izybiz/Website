---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog-fr");
  const enPosts = await getCollection("blog-en");
  const esPosts = await getCollection("blog-es");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post, enPosts, esPosts, posts },
  }));
}

const { post, enPosts, esPosts, posts } = Astro.props;
const { Content } = await render(post);
const lang = "fr";
const pubDate = post.data.pubDate.toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" });
const currentSlug = post.id.replace(/\.md$/, "");
const sortedPosts = [...posts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentPostIndex = sortedPosts.findIndex((item) => item.id === post.id);
const newerPost = currentPostIndex > 0 ? sortedPosts[currentPostIndex - 1] : null;
const olderPost = currentPostIndex < sortedPosts.length - 1 ? sortedPosts[currentPostIndex + 1] : null;
const newerPath = newerPost ? `/blog/${newerPost.id.replace(/\.md$/, "")}` : null;
const olderPath = olderPost ? `/blog/${olderPost.id.replace(/\.md$/, "")}` : null;

// Find translated slugs via translationKey
const tk = post.data.translationKey;
const enPost = enPosts.find((p) => p.data.translationKey === tk);
const esPost = esPosts.find((p) => p.data.translationKey === tk);
const enPath = enPost ? `/en/blog/${enPost.id.replace(/\.md$/, "")}` : "/en/blog";
const esPath = esPost ? `/es/blog/${esPost.id.replace(/\.md$/, "")}` : "/es/blog";
const currentPath = `/blog/${currentSlug}`;
---

<Layout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  includeGlobalScript={true}
  canonicalPath={currentPath}
  alternates={{ fr: currentPath, en: enPath, es: esPath }}
>
  <main>
    <div class="article-page-shell">
      <nav class="article-page__arrow-nav" aria-label="Navigation des articles">
        {newerPath ? (
          <a class="article-page__arrow-button" href={newerPath} aria-label="Aller à l'article plus récent">←</a>
        ) : (
          <span class="article-page__arrow-spacer" aria-hidden="true"></span>
        )}
        {olderPath ? (
          <a class="article-page__arrow-button" href={olderPath} aria-label="Aller à l'article plus ancien">→</a>
        ) : (
          <span class="article-page__arrow-spacer" aria-hidden="true"></span>
        )}
      </nav>
    </div>
    <article class="article-page">
      <h1 class="article-page__title">{post.data.title}</h1>
      <p class="article-page__description">{post.data.description}</p>
      <time class="article-page__date" datetime={post.data.pubDate.toISOString()}>{pubDate}</time>
      <div class="article-page__body">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .article-page-shell {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(16px, 3vw, 28px);
  }

  .article-page__arrow-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 44px 0 14px;
  }

  .article-page__arrow-button,
  .article-page__arrow-spacer {
    width: 44px;
    height: 44px;
    border-radius: 999px;
  }

  .article-page__arrow-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    color: #000000;
    border: 0;
    text-decoration: none;
    font-size: 22px;
    line-height: 1;
    transition:
      transform 160ms ease,
      background-color 160ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .article-page__arrow-button:hover {
      background: #f5f5f5;
      transform: translateY(-1px);
    }
  }

  .article-page__arrow-button:focus-visible {
    outline: 2px solid #000000;
    outline-offset: 3px;
  }

  .article-page__arrow-button:active {
    transform: translateY(0);
  }
</style>
