---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "../../i18n/translations";

const lang = "fr";
const t = useTranslations(lang);
const posts = (await getCollection("blog-fr"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout lang={lang} title="Blog transformation & IA pour dirigeants | Izybiz" description="Articles terrain sur le management de transition, l'intégration IA et la transformation opérationnelle pour dirigeants d'ETI et scale-ups." includeGlobalScript={true}>
  <main class="blog-page">
    <div class="blog-index">
      <header class="blog-index__header">
        <h1 class="blog-index__title">Terrain. Pas théorie.</h1>
        <p class="blog-index__subtitle">{t("blog.subtitle")}</p>
      </header>
      <ul class="blog-list">
        {posts.map((post) => {
          const slug = post.id.replace(/\.md$/, "");
          const date = post.data.pubDate.toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" });
          return (
            <li class="blog-card">
              <a class="blog-card__link" href={`/blog/${slug}/`}>
                <time class="blog-card__date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                <div class="blog-card__content">
                  <h2 class="blog-card__title">{post.data.title}</h2>
                  <p class="blog-card__description">{post.data.description}</p>
                </div>
                <span class="blog-card__cta">{t("blog.readmore")}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </main>
</Layout>
