---
import Layout from "../layouts/Layout.astro";
import HomeContent from "../components/HomeContent.astro";
import HomeContentEs from "../components/HomeContentEs.astro";
import HomeContentFr from "../components/HomeContentFr.astro";
import { getLangFromUrl } from "../i18n/translations";

const lang = (Astro.currentLocale || getLangFromUrl(Astro.url)) as "fr" | "en" | "es";
---

<Layout
  lang={lang}
  title="Management de transition & intégration IA pour ETI | Izybiz"
  description="Stéphane Dinepro — management de transition et intégration IA pour ETI et scale-ups français. 30 ans d'expérience. Clients Bouygues, SNCF, Canal+. Réponse sous 48h."
  includeGlobalScript={true}
>
  {lang === "es" ? <HomeContentEs /> : lang === "fr" ? <HomeContentFr /> : <HomeContent />}
</Layout>
