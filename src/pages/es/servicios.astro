---
import Layout from "../../layouts/Layout.astro";
import { getLocalizedPath } from "../../i18n/translations";

const lang = "es";

const services = [
  {
    title: "Management de Transición",
    description: "Un ejecutivo operacional disponible en semanas. No un informe — un rol real, con sus equipos, sobre sus desafíos concretos. Resultados medibles desde el día 30.",
    href: getLocalizedPath("transition", lang),
    tags: ["DG / COO / CDO interino", "Transformación que deriva", "Dirección vacante", "Scale-up pre-Serie B"],
  },
  {
    title: "Integración IA en la empresa",
    description: "Del POC a producción real. Definición de casos de uso, selección de vendors, diseño de workflows, despliegue. La organización sale autónoma — sin dependencia de consultores.",
    href: getLocalizedPath("ai", lang),
    tags: ["Definición casos de uso", "Gobernanza IA", "Workflows operacionales", "Salida independiente"],
  },
  {
    title: "Gestión del Rendimiento",
    description: "Implantación de KPIs estructurantes, bucles de retroalimentación y rituales de gestión que permiten a una organización pilotar por resultados — no por intuición.",
    href: getLocalizedPath("performance", lang),
    tags: ["KPIs estructurantes", "Cuadros de mando", "Rituales de gestión", "Cultura data"],
  },
  {
    title: "Reestructuración Operacional",
    description: "Cuando una BU deriva — churn acelerado, márgenes en caída, caja bajo presión. Diagnóstico rápido, plan de acción priorizado, ejecución sin calentamiento previo.",
    href: getLocalizedPath("turnaround", lang),
    tags: ["BU en dificultad", "Reestructuración operacional", "Caja y márgenes", "Plan de acción D15"],
  },
  {
    title: "Scale-up e Industrialización",
    description: "Los procesos que funcionan a 10 personas se rompen a 80. Estructuración del delivery, los equipos y las operaciones antes de que el crecimiento se convierta en el problema.",
    href: getLocalizedPath("scaleup", lang),
    tags: ["Estructuración pre-Serie B", "Delivery y operaciones", "Procesos escalables", "Diseño org objetivo"],
  },
];
---

<Layout
  lang={lang}
  title="Management de Transición & Transformación Operacional — Izybiz"
  description="Un directivo operacional disponible en semanas, no en meses. Management de transición, integración IA y transformación operacional para empresas medianas y scale-ups."
  navType="page"
  includeGlobalScript={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Servicios de management de transición y transformación operacional — Izybiz",
      "url": "https://izybiz.fr/es/servicios/",
      "itemListElement": services.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Service",
          "name": s.title,
          "description": s.description,
          "url": `https://izybiz.fr${s.href}`,
          "provider": {
            "@type": "Organization",
            "name": "Izybiz",
            "url": "https://izybiz.fr"
          }
        }
      }))
    })} />
  </Fragment>
  <main>
    <div class="services-page">
      <header class="services-page__header">
        <h1 class="services-page__title">Management de transición y transformación operacional</h1>
        <p class="services-page__intro">Cinco tipos de misión. Todas operacionales. Todas con un objetivo único: que su organización salga autónoma al final — sin dependencia de consultores.</p>
        <a href={getLocalizedPath("about", lang)} class="services-page__intro-link">Sobre el enfoque</a>
      </header>

      <ul class="services-list">
        {services.map((service, index) => (
          <li
            class="services-card"
            style={index === 0 ? "--services-card-bg: #d9d8ff; --services-tag-bg: #ffffff; --services-tag-color: #000000;" : undefined}
          >
            <a
              class="services-card__hitbox"
              href={service.href}
              aria-label={`Saber más sobre ${service.title}`}
            ></a>
            <div class="services-card__content">
              <h2 class="services-card__title">{service.title}</h2>
              <p class="services-card__description">{service.description}</p>
              <ul class="services-card__tags">
                {service.tags.map((tag) => (
                  <li class="services-card__tag">{tag}</li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ul>

      <div class="services-page__cta">
        <p>¿Su situación no encaja exactamente en una categoría?</p>
        <a href={getLocalizedPath("contact", lang)} class="services-page__cta-link">Hablemos !</a>
      </div>
    </div>
  </main>
</Layout>
