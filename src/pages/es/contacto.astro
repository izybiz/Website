---
import Layout from "../../layouts/Layout.astro";

const lang = "es";
---

<Layout
  lang={lang}
  title="Contactar — director interino experto | Izybiz"
  description="Un intercambio de 30 minutos para ver si su situación requiere un director interino experto o integración IA. Sin argumentario. Respuesta en 48h."
  includeGlobalScript={true}
  canonicalPath="/es/contacto"
  alternates={{ fr: "/contact", en: "/en/contact", es: "/es/contacto" }}
>
  <main>
    <article class="article-page">
      <h1 class="article-page__title">Contactar</h1>
      <p class="article-page__description">Sin argumentario de ventas. Un intercambio de 30 minutos para ver si su situación requiere un management de transición o una integración IA — y si Izybiz es el perfil adecuado.</p>

      <div class="article-page__body">
        <h2>Qué ocurre después de su mensaje</h2>
        <ol>
          <li><strong>Respuesta en 48h</strong> — con una propuesta de horario para un intercambio telefónico o por videoconferencia.</li>
          <li><strong>Intercambio de descubrimiento de 30 minutos</strong> — describe su situación, sus retos, su restricción de tiempo.</li>
          <li><strong>Si es pertinente</strong> — le propongo un encuadre de misión. Usted decide.</li>
        </ol>
        <p>Ningún compromiso en ninguna etapa.</p>

        <form
          class="contact-form"
          method="POST"
          action="https://api.web3forms.com/submit"
        >
          <input type="hidden" name="access_key" value="ae024e50-5c9a-418c-9a35-0572c0dea506" />
          <input type="hidden" name="subject" value="[izybiz.fr] Nuevo contacto" />
          <input type="hidden" name="redirect" value="https://izybiz.fr/es/contacto/gracias/" />
          <input type="checkbox" name="botcheck" style="display: none;" />

          <div class="contact-form__field">
            <label class="contact-form__label" for="nombre">Nombre *</label>
            <input class="contact-form__input" type="text" id="nombre" name="nombre" placeholder="Nombre y apellidos" required />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="empresa">Empresa</label>
            <input class="contact-form__input" type="text" id="empresa" name="empresa" placeholder="Nombre de la empresa" />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="cargo">Cargo</label>
            <input class="contact-form__input" type="text" id="cargo" name="cargo" placeholder="Su función" />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="email">Email *</label>
            <input class="contact-form__input" type="email" id="email" name="email" placeholder="su@email.com" required />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="situacion">Su situación *</label>
            <textarea class="contact-form__textarea" id="situacion" name="situacion" rows="5" placeholder="Cuál es el reto, cuál es la urgencia, qué ha intentado ya." required></textarea>
          </div>

          <button class="contact-form__submit" type="submit">Enviar</button>
        </form>

        <hr />
        <p><em>También puede encontrar a Stéphane en <a href="https://www.linkedin.com/company/izybiz/" target="_blank" rel="noopener noreferrer">LinkedIn</a> antes de contactar.</em></p>
      </div>
    </article>
  </main>
</Layout>
