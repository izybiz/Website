---
import Layout from "../layouts/Layout.astro";
import { getEntry, render } from "astro:content";

const lang = "fr";
const page = await getEntry("pages-fr", "pilotage-performance");
const { Content } = await render(page);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Pilotage de la performance",
  "name": page.data.title,
  "description": page.data.description,
  "url": "https://izybiz.fr/pilotage-performance/",
  "areaServed": "France",
  "provider": {
    "@type": "Organization",
    "name": "Izybiz",
    "url": "https://izybiz.fr"
  }
};
---
<Layout
  lang={lang}
  title={page.data.title}
  description={page.data.description}
  navType="page"
  includeGlobalScript={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>
  <main>
    <article class="article-page article-page--wide">
      <a class="services-page__intro-link service-detail__back-link" href="/services/">← Services</a>
      <h1 class="article-page__title">{page.data.title}</h1>
      <p class="article-page__description">{page.data.description}</p>
      <div class="article-page__body">
        <Content />
      </div>
    </article>
  </main>
</Layout>
