---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render } from "astro:content";

const lang = "en";
const page = await getEntry("pages-en", "interim-management");
const { Content } = await render(page);
---

<Layout lang={lang} title={page.data.title} description={page.data.description} includeGlobalScript={true}>
  <main>
    <article class="article-page article-page--wide">
      <a class="services-page__intro-link service-detail__back-link" href="/en/services/">← Services</a>
      <h1 class="article-page__title">{page.data.title}</h1>
      <p class="article-page__description">{page.data.description}</p>
      <div class="article-page__body"><Content /></div>
    </article>
  </main>
</Layout>
