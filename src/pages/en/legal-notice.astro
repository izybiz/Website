---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render } from "astro:content";

const lang = "en";
const page = await getEntry("pages-en", "legal-notice");
const { Content } = await render(page);
---

<Layout lang={lang} title={page.data.title} description={page.data.description} includeGlobalScript={true}>
  <main class="legal-main">
    <div class="legal-inner">
      <Content />
    </div>
  </main>
</Layout>

<style>
  :global(body) {
    background: #fff;
  }

  .legal-main {
    max-width: 980px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .legal-inner {
    font-family: "Didact Gothic", sans-serif;
  }

  .legal-inner :global(h1),
  .legal-inner :global(h2) {
    font-family: "Bricolage Grotesque", sans-serif;
    font-size: clamp(28px, 4vw, 46px);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .legal-inner :global(h3),
  .legal-inner :global(h4),
  .legal-inner :global(h5),
  .legal-inner :global(h6) {
    font-family: "Bricolage Grotesque", sans-serif;
  }
  .legal-inner :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }
  .legal-inner :global(li),
  .legal-inner :global(td),
  .legal-inner :global(th),
  .legal-inner :global(a) {
    font-family: "Didact Gothic", sans-serif;
  }
  .legal-inner :global(hr) {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid #e5e7eb;
  }
  :global(.legal-inner table) {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  :global(.legal-inner th),
  :global(.legal-inner td) {
    padding: 0.85rem 1rem;
    text-align: left;
    border: 1px solid;
  }
  :global(.legal-inner th) {
    font-family: "Didact Gothic", sans-serif;
    font-weight: 800;
  }
  :global(.legal-inner td) {
    font-family: "Didact Gothic", sans-serif;
    font-weight: 400;
  }

  /* Table variant 1: blue */
  :global(.legal-inner table:nth-of-type(1)) {
    background: #dbeafe;
    border-color: #93c5fd;
  }
  :global(.legal-inner table:nth-of-type(1) th),
  :global(.legal-inner table:nth-of-type(1) td) {
    border-color: #93c5fd;
  }
  :global(.legal-inner table:nth-of-type(1) th) {
    background: #bfdbfe;
    color: #0f172a;
  }

  /* Table variant 2: yellow */
  :global(.legal-inner table:nth-of-type(2)) {
    background: #fef3c7;
    border-color: #f59e0b;
  }
  :global(.legal-inner table:nth-of-type(2) th),
  :global(.legal-inner table:nth-of-type(2) td) {
    border-color: #f59e0b;
  }
  :global(.legal-inner table:nth-of-type(2) th) {
    background: #fde68a;
    color: #422006;
  }

  /* Table variant 3: violet */
  :global(.legal-inner table:nth-of-type(3)) {
    background: #ede9fe;
    border-color: #a78bfa;
  }
  :global(.legal-inner table:nth-of-type(3) th),
  :global(.legal-inner table:nth-of-type(3) td) {
    border-color: #a78bfa;
  }
  :global(.legal-inner table:nth-of-type(3) th) {
    background: #ddd6fe;
    color: #2e1065;
  }
</style>
