---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "../../../i18n/translations";

const lang = "en";
const t = useTranslations(lang);
const posts = (await getCollection("blog-en")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout lang={lang} title="Blog — AI Integration & Interim Management | Izybiz" description={t("blog.subtitle")} includeGlobalScript={true}>
  <main class="blog-page">
    <div class="blog-index">
      <header class="blog-index__header">
        <h1 class="blog-index__title">Field experience. Not frameworks.</h1>
        <p class="blog-index__subtitle">{t("blog.subtitle")}</p>
      </header>
      <ul class="blog-list">
        {posts.map((post) => {
          const slug = post.id.replace(/\.md$/, "");
          const date = post.data.pubDate.toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" });
          return (
            <li class="blog-card">
              <a class="blog-card__link" href={`/en/blog/${slug}/`}>
                <time class="blog-card__date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                <div class="blog-card__content">
                  <h2 class="blog-card__title">{post.data.title}</h2>
                  <p class="blog-card__description">{post.data.description}</p>
                </div>
                <span class="blog-card__cta">{t("blog.readmore")}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </main>
</Layout>
