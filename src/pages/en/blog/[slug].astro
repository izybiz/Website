---
import Layout from "../../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog-en");
  const frPosts = await getCollection("blog-fr");
  const esPosts = await getCollection("blog-es");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post, frPosts, esPosts, posts },
  }));
}

const { post, frPosts, esPosts, posts } = Astro.props;
const { Content } = await render(post);
const lang = "en";
const pubDate = post.data.pubDate.toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" });
const currentSlug = post.id.replace(/\.md$/, "");
const sortedPosts = [...posts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentPostIndex = sortedPosts.findIndex((item) => item.id === post.id);
const newerPost = currentPostIndex > 0 ? sortedPosts[currentPostIndex - 1] : null;
const olderPost = currentPostIndex < sortedPosts.length - 1 ? sortedPosts[currentPostIndex + 1] : null;
const newerPath = newerPost ? `/en/blog/${newerPost.id.replace(/\.md$/, "")}/` : null;
const olderPath = olderPost ? `/en/blog/${olderPost.id.replace(/\.md$/, "")}/` : null;

const tk = post.data.translationKey;
const frPost = frPosts.find((p) => p.data.translationKey === tk);
const esPost = esPosts.find((p) => p.data.translationKey === tk);
const frPath = frPost ? `/blog/${frPost.id.replace(/\.md$/, "")}/` : "/blog/";
const esPath = esPost ? `/es/blog/${esPost.id.replace(/\.md$/, "")}/` : "/es/blog/";
const currentPath = `/en/blog/${currentSlug}/`;
---

<Layout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  pubDate={post.data.pubDate.toISOString()}
  includeGlobalScript={true}
  canonicalPath={currentPath}
  alternates={{ fr: frPath, en: currentPath, es: esPath }}
>
  <main>
    <div class="article-page-shell">
      <nav class="article-page__arrow-nav" aria-label="Article navigation">
        {newerPath ? (
          <a class="article-page__arrow-button" href={newerPath} aria-label="Go to newer article">←</a>
        ) : (
          <span class="article-page__arrow-spacer" aria-hidden="true"></span>
        )}
        {olderPath ? (
          <a class="article-page__arrow-button" href={olderPath} aria-label="Go to older article">→</a>
        ) : (
          <span class="article-page__arrow-spacer" aria-hidden="true"></span>
        )}
      </nav>
    </div>
    <article class="article-page">
      <h1 class="article-page__title">{post.data.title}</h1>
      <p class="article-page__description">{post.data.description}</p>
      <time class="article-page__date" datetime={post.data.pubDate.toISOString()}>{pubDate}</time>
      <div class="article-page__body">
        <Content />
      </div>
    </article>
    <aside class="article-services-cta" aria-label="Our services">
      <h2 class="article-services-cta__title">Our missions</h2>
      <ul class="article-services-cta__list">
        <li><a href="/en/management-transition/">Interim management</a> — Operational leadership for mid-sized companies and scale-ups during critical phases.</li>
        <li><a href="/en/ai-integration/">AI integration in business</a> — From POC to production, with governance and autonomous teams at handover.</li>
        <li><a href="/en/performance-management/">Performance management</a> — Executive dashboards and operating KPIs that drive decisions.</li>
        <li><a href="/en/operational-turnaround/">Operational turnaround</a> — Business unit recovery in high-pressure situations.</li>
        <li><a href="/en/scale-up-operations/">Scale-up industrialization</a> — Structure delivery and processes to grow without breaking operations.</li>
      </ul>
    </aside>
  </main>
</Layout>

<style>
  .article-page-shell {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(16px, 3vw, 28px);
  }

  .article-page__arrow-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 44px 0 14px;
  }

  .article-page__arrow-button,
  .article-page__arrow-spacer {
    width: 44px;
    height: 44px;
    border-radius: 999px;
  }

  .article-page__arrow-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    color: #000000;
    border: 0;
    text-decoration: none;
    font-size: 22px;
    line-height: 1;
    transition:
      transform 160ms ease,
      background-color 160ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .article-page__arrow-button:hover {
      background: #f5f5f5;
      transform: translateY(-1px);
    }
  }

  .article-page__arrow-button:focus-visible {
    outline: 2px solid #000000;
    outline-offset: 3px;
  }

  .article-page__arrow-button:active {
    transform: translateY(0);
  }
</style>
